{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel-build",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api"
    },
    {
      "source": "/admin.html",
      "destination": "/api"
    },
    {
      "source": "/admin-product.html",
      "destination": "/api"
    },
    {
      "source": "/orders.html",
      "destination": "/api"
    },
    {
      "source": "/admin.js",
      "destination": "/api"
    },
    {
      "source": "/admin-product.js",
      "destination": "/api"
    },
    {
      "source": "/orders.js",
      "destination": "/api"
    }
  ]
}
